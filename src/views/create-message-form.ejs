<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Message | Clubhouse</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="form-container">
        <h1>Post a New Message</h1>
        <p>Your message will be visible to everyone, but your name will stay hidden from non-members.</p>

        <% if (locals.errors) { %>
            <div class="error-box">
                <ul>
                    <% errors.forEach(function(error) { %>
                        <li><%= error.msg %></li>
                    <% }); %>
                </ul>
            </div>
        <% } %>

        <form action="/create-message" method="POST">
            <div class="form-group">
                <label for="title">Title</label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    placeholder="Enter a catchy title" 
                    required 
                    maxlength="100"
                >
            </div>

            <div class="form-group">
                <label for="text">Message Content</label>
                <textarea 
                    id="text" 
                    name="text" 
                    rows="5" 
                    placeholder="What's on your mind?" 
                    required
                ></textarea>
            </div>

            <button type="submit" class="btn-submit">Publish Message</button>
        </form>

        <p class="footer-text">
            <a href="/">Cancel and go back</a>
        </p>
    </div>
</body>
</html>